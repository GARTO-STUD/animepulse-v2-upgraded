# ─── REQUIRED ────────────────────────────────────────────────────────────────
# Firebase service account JSON (stringified, one line)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"YOUR_PROJECT","private_key":"...","client_email":"..."}

# ─── AI PROVIDERS (at least one required for AutoPilot) ──────────────────────
# Groq (primary - fast and free tier generous)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_...

# Google Gemini (fallback)
# Get key at: https://makersuite.google.com
GEMINI_API_KEY=AIza...

# ─── ADMIN SECURITY ──────────────────────────────────────────────────────────
# Password for /admin dashboard (change this!)
ADMIN_PASSWORD=your-secure-admin-password-here

# Shared with client for legacy review page (keep same as ADMIN_PASSWORD)
NEXT_PUBLIC_REVIEW_PASSWORD=your-secure-admin-password-here

# Secret for triggering AutoPilot via cron job
CRON_SECRET=your-cron-secret-here

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://animepulse.online

# ─── MONETIZATION (optional) ─────────────────────────────────────────────────
# Google AdSense publisher ID (when approved)
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXXX

# ─── SEO ─────────────────────────────────────────────────────────────────────
# Google Search Console verification code
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── TELEGRAM (optional - for auto-publishing to channel) ────────────────────
# TELEGRAM_BOT_TOKEN=xxxx:xxxxxxxx
# TELEGRAM_CHANNEL_ID=@AnimePulseChannel
